const policies = require("../policies/policies.json");

function evaluateCondition(condition, req) {
  return Object.keys(condition).every((key) => {
    const [source, field] = key.split(".");
    return req[source]?.[field] === condition[key];
  });
}

const abac = (action, resource) => {
  return (req, res, next) => {
    const allowed = policies.some((policy) => {
      return (
        policy.action === action &&
        policy.resource === resource &&
        evaluateCondition(policy.condition, req)
      );
    });

    if (!allowed) {
      return res.status(403).json({ message: "Access denied (ABAC)" });
    }

    next();
  };
};

module.exports = abac;
